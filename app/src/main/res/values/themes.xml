<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Projectyear" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>
        <item name="colorPrimaryContainer">@color/md_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/md_on_primary_container</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>
        <item name="colorSecondaryContainer">@color/md_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/md_on_secondary_container</item>

        <!-- Tertiary -->
        <item name="colorTertiary">@color/md_tertiary</item>
        <item name="colorOnTertiary">@color/md_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/md_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/md_on_tertiary_container</item>

        <!-- Error -->
        <item name="colorError">@color/md_error</item>
        <item name="colorOnError">@color/md_on_error</item>

        <!-- Surface -->
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>
        <item name="colorSurfaceVariant">@color/md_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/md_on_surface_variant</item>
        <item name="android:colorBackground">@color/md_background</item>
        <item name="colorOnBackground">@color/md_on_background</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/md_on_surface</item>
        <item name="android:textColorSecondary">@color/md_on_surface_variant</item>
    </style>

    <!-- Splash — no animation flash -->
    <style name="Theme.Projectyear.Splash" parent="Theme.Projectyear">
        <item name="android:windowBackground">@color/md_primary</item>
        <item name="android:statusBarColor">@color/md_primary</item>
        <item name="android:navigationBarColor">@color/md_primary</item>
    </style>

    <!-- Login full screen -->
    <style name="Theme.Projectyear.Login" parent="Theme.Projectyear">
        <item name="android:windowBackground">@color/md_background</item>
    </style>

    <!-- Text Appearances -->
    <style name="TextAppearance.Cafe.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/md_on_surface</item>
    </style>

    <style name="TextAppearance.Cafe.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/md_on_surface</item>
    </style>

    <style name="TextAppearance.Cafe.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/md_on_surface</item>
    </style>

    <style name="TextAppearance.Cafe.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/md_on_surface_variant</item>
    </style>

    <!-- Card style -->
    <style name="Widget.Cafe.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardElevation">2dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardBackgroundColor">@color/md_surface</item>
    </style>

    <!-- Outlined Card -->
    <style name="Widget.Cafe.Card.Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">12dp</item>
        <item name="strokeColor">@color/md_outline_variant</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <!-- Primary Button -->
    <style name="Widget.Cafe.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.Cafe.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Tonal Button -->
    <style name="Widget.Cafe.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.Cafe.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
    </style>

    <!-- Chip Filter -->
    <style name="Widget.Cafe.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipCornerRadius">20dp</item>
    </style>

</resources>