<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_background">

    <!-- Profile Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/md_primary"
        android:padding="24dp"
        android:paddingTop="40dp"
        android:gravity="center">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginBottom="12dp">
            <TextView
                android:id="@+id/tv_avatar"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/bg_avatar_circle"
                android:gravity="center"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/md_primary"
                android:text=""/>
        </FrameLayout>

        <TextView
            android:id="@+id/tv_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="16sp"
            android:textColor="#FFFBF7"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_orders_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 orders"
            android:textSize="12sp"
            android:textColor="#BCAAA4"/>

    </LinearLayout>

    <!-- Order History Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/lbl_order_history"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.Cafe.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_logout"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>

    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_profile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:visibility="gone"/>

    <!-- Empty Orders State -->
    <LinearLayout
        android:id="@+id/ll_no_orders"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📋" android:textSize="48sp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/no_orders_title"
            android:textSize="18sp" android:textStyle="bold"
            android:textColor="@color/md_on_surface" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/no_orders_subtitle"
            android:textSize="14sp" android:textColor="@color/md_on_surface_variant"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Orders RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_orders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"/>

</LinearLayout>
