<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_small"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Item Image -->
        <ImageView
            android:id="@+id/iv_item_image"
            android:layout_width="match_parent"
            android:layout_height="@dimen/menu_item_image_height"
            android:scaleType="centerCrop"
            android:background="@color/light_gray" />

        <!-- Item Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_medium">

            <!-- Category -->
            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Coffee"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/cafe_dark_brown"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_xsmall" />

            <!-- Item Name -->
            <TextView
                android:id="@+id/tv_item_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Espresso"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:layout_marginBottom="@dimen/spacing_xsmall" />

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Rich and strong coffee"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_light"
                android:layout_marginBottom="@dimen/spacing_medium"
                android:maxLines="2"
                android:ellipsize="end" />

            <!-- Price and Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:spacing="@dimen/spacing_medium">

                <!-- Price -->
                <TextView
                    android:id="@+id/tv_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rs. 150"
                    android:textSize="@dimen/text_size_subtitle"
                    android:textStyle="bold"
                    android:textColor="@color/cafe_brown" />

                <!-- Add to Cart Button -->
                <Button
                    android:id="@+id/btn_add_to_cart"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_add_to_cart"
                    android:textSize="@dimen/text_size_small"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/cafe_brown"
                    android:paddingHorizontal="@dimen/spacing_medium" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</androidx.cardview.widget.CardView>

