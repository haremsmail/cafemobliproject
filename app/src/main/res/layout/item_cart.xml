<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/Widget.Cafe.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="4dp"
    android:layout_marginEnd="4dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Name + price column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_item_name_cart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Item Name"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tv_unit_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IQD 0 each"
                android:textSize="12sp"
                android:textColor="@color/md_on_surface_variant"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tv_item_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IQD 0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/md_primary"/>

        </LinearLayout>

        <!-- Quantity stepper + remove -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/btn_decrease"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_input_delete"
                    android:background="@drawable/bg_stepper_btn"
                    android:contentDescription="Decrease"/>

                <TextView
                    android:id="@+id/tv_quantity"
                    android:layout_width="36dp"
                    android:layout_height="wrap_content"
                    android:text="1"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface"
                    android:gravity="center"/>

                <ImageButton
                    android:id="@+id/btn_increase"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/ic_input_add"
                    android:background="@drawable/bg_chip_primary"
                    android:tint="#FFFFFF"
                    android:contentDescription="Increase"/>

            </LinearLayout>

            <ImageButton
                android:id="@+id/btn_remove_item"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:tint="@color/md_error"
                android:contentDescription="Remove"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
