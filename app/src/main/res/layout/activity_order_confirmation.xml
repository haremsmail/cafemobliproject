<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_large"
    android:gravity="center"
    android:background="@color/cafe_beige">

    <!-- Confirmation Icon/Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/confirmation_title"
        android:textSize="@dimen/text_size_heading"
        android:textStyle="bold"
        android:textColor="@color/accent_green"
        android:textAlignment="center"
        android:layout_marginBottom="@dimen/spacing_large" />

    <!-- Order Details Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_large"
        android:background="@color/white"
        android:layout_marginBottom="@dimen/spacing_large">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/order_details"
            android:textSize="@dimen/text_size_title"
            android:textStyle="bold"
            android:textColor="@color/cafe_brown"
            android:layout_marginBottom="@dimen/spacing_medium" />

        <!-- Order ID -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_small">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lbl_order_id"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/tv_order_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12345"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Order Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_small">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lbl_order_time"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/tv_order_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:30 PM"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/spacing_medium">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/lbl_status"
                android:textSize="@dimen/text_size_body" />

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_confirmed"
                android:textSize="@dimen/text_size_body"
                android:textStyle="bold"
                android:textColor="@color/accent_green" />
        </LinearLayout>

        <!-- Total Price -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/light_gray"
            android:layout_marginVertical="@dimen/spacing_small" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total:"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_confirmation_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rs. 0.00"
                android:textSize="@dimen/text_size_subtitle"
                android:textStyle="bold"
                android:textColor="@color/cafe_brown" />
        </LinearLayout>
    </LinearLayout>

    <!-- Message -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/msg_thank_you"
        android:textSize="@dimen/text_size_subtitle"
        android:textColor="@color/cafe_dark_brown"
        android:textAlignment="center"
        android:layout_marginBottom="@dimen/spacing_small" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/msg_estimated_time"
        android:textSize="@dimen/text_size_body"
        android:textColor="@color/text_light"
        android:textAlignment="center"
        android:layout_marginBottom="@dimen/spacing_large" />

    <!-- Back to Home Button -->
    <Button
        android:id="@+id/btn_back_home"
        android:layout_width="match_parent"
        android:layout_height="@dimen/button_height"
        android:text="@string/btn_back_home"
        android:textSize="@dimen/text_size_subtitle"
        android:textColor="@color/white"
        android:backgroundTint="@color/cafe_brown" />

</LinearLayout>

