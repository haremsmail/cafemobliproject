<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/md_background"
    android:padding="32dp">

    <!-- Success Icon -->
    <TextView
        android:id="@+id/tv_confirm_icon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:text="✓"
        android:textSize="52sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/bg_avatar_circle"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:id="@+id/tv_confirm_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirmation_title"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/md_primary"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_confirm_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/confirmation_subtitle"
        android:textSize="15sp"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginBottom="32dp"/>

    <!-- Order Card -->
    <androidx.cardview.widget.CardView
        style="@style/Widget.Cafe.Card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tv_order_id_confirm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Order #"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"
                android:layout_marginBottom="8dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="6dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="Total paid"
                    android:textSize="14sp" android:textColor="@color/md_on_surface_variant"/>
                <TextView android:id="@+id/tv_total_confirm"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="IQD 0" android:textSize="14sp" android:textStyle="bold"
                    android:textColor="@color/md_primary"/>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="@string/lbl_estimated"
                    android:textSize="14sp" android:textColor="@color/md_on_surface_variant"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="@string/lbl_15_mins" android:textSize="14sp"
                    android:textColor="@color/status_confirmed" android:textStyle="bold"/>
            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Back to Home -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_back_home"
        style="@style/Widget.Cafe.Button"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="@string/btn_back_home"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_view_my_orders"
        style="@style/Widget.Cafe.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="@string/btn_view_orders"
        android:textSize="16sp"/>

</LinearLayout>
