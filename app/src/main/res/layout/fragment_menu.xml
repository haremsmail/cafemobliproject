<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/md_background">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/md_surface"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/md_primary"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/menu_subtitle"
            android:textSize="13sp"
            android:textColor="@color/md_on_surface_variant"
            android:layout_marginBottom="12dp"/>

        <!-- Chip Filter -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_all"
                    style="@style/Widget.Cafe.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_all"
                    android:checked="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_coffee"
                    style="@style/Widget.Cafe.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_coffee"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_tea"
                    style="@style/Widget.Cafe.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_tea"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_desserts"
                    style="@style/Widget.Cafe.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/filter_desserts"/>

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Loading -->
    <ProgressBar
        android:id="@+id/progress_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="32dp"
        android:visibility="gone"/>

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/ll_empty_state"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="🫗" android:textSize="48sp" android:layout_marginBottom="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/menu_empty_title"
            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/md_on_surface"
            android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/menu_empty_subtitle"
            android:textSize="14sp" android:textColor="@color/md_on_surface_variant"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Menu RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="12dp"/>

</LinearLayout>
